NODE_ENV=production
PORT=3000
DATABASE_URL="__REPLACE_ME_SUPABASE_RUNTIME_URL__"
DIRECT_URL="__REPLACE_ME_SUPABASE_DIRECT_URL__"
JWT_SECRET="__REPLACE_ME_STRONG_SECRET__"
REFRESH_TOKEN_SECRET="__REPLACE_ME_REFRESH_SECRET__"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
CORS_ORIGINS="__REPLACE_ME_ALLOWED_ORIGINS__"
LOG_LEVEL="log"
SWAGGER_ENABLED="false"
BCRYPT_ROUNDS=12
COOKIE_NAME="fd_access_token"
REFRESH_COOKIE_NAME="fd_refresh_token"
CSRF_COOKIE_NAME="fd_csrf_token"
COOKIE_SECURE="true"
COOKIE_SAME_SITE="none"
COOKIE_DOMAIN="__REPLACE_ME_COOKIE_DOMAIN__"
